<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_analytic_account_recurring_form_form" model="ir.ui.view">
        <field name="name">Contract form</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_form"/>
        <field name="mode">primary</field>
        <field name="priority" eval="9999"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="attributes">
                <attribute name="attrs">{'required': [('recurring_invoices', '=', True)]}</attribute>
            </field>
            <xpath expr="//div[@name='button_box']/.." position="before">
                <header>
                    <button name="action_contract_send" type="object" string="Send by Email" groups="base.group_user"/>
                </header>
            </xpath>
            <group name="main" position="after">
                <group name="main">
                          <group name="group_main_left">
                         <field name="meter_contractid" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                 <field name="partner_old_id" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                 <field name="meter_id" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                 <field name="meter_chechid" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                 <field name="date_Sub_start" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                  <field name="meter_first_reading" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                     <field name="meter_val" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                   <field name="meter_uses"/>
                       <field name="meter_vastype" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        <field name="meter_type" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        <field name="meter_canusedunit" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                     </group>
                    <group name="group_main_right">
                        <field name="meter_cableid" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        <field name="meter_cablename" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        <field name="meter_cabletype" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                         <field name="date_contract" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                          <field name="meter_idcard" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        <field name="meter_cardtype" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        <field name="meter_cardprint" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        <field name="date_idcard" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        <field name="meter_current_reading" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        <field name="datetime_lastreading" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                        </group>
                        </group>
                <separator string="Recurring Invoices"
                           attrs="{'invisible': [('recurring_invoices','!=',True)]}"
                           />
                <div>
                    <field name="recurring_invoices" class="oe_inline"/>
                    <field name="create_invoice_visibility" invisible="1"/>
                    <label for="recurring_invoices" />
                    <button name="recurring_create_invoice"
                            type="object"
                            attrs="{'invisible': ['|', ('recurring_invoices', '!=', True), ('create_invoice_visibility', '=', False)]}"
                            string="Create invoices"
                            class="oe_link"
                            groups="base.group_no_one"
                            />
                    <button name="contract.act_recurring_invoices"
                            type="action"
                            attrs="{'invisible': [('recurring_invoices','!=',True)]}"
                            string="⇒ Show recurring invoices"
                            class="oe_link"
                            />
                </div>
                <group col="4" attrs="{'invisible': [('recurring_invoices','!=',True)]}">
                    <field name="contract_template_id" colspan="4" attrs="{'required': [('recurring_invoices', '=', True)]}"/>
                    <field name="journal_id"
                           attrs="{'required': [('recurring_invoices', '=', True)]}"
                    />
                    <field name="pricelist_id"/>
                    <label for="recurring_interval"/>
                    <div>
                        <field name="recurring_interval"
                               class="oe_inline"
                               attrs="{'required': [('recurring_invoices', '=', True)]}"
                               />
                        <field name="recurring_rule_type"
                               class="oe_inline"
                               attrs="{'required': [('recurring_invoices', '=', True)]}"
                               />
                    </div>
                    <field name="recurring_invoicing_type"
                           attrs="{'required': [('recurring_invoices', '=', True)]}"
                    />
                    <field name="date_start"
                           attrs="{'required': [('recurring_invoices', '=', True)]}"
                    />
                    <field name="date_end"/>
                    <field name="recurring_next_date"
                           attrs="{'required': [('recurring_invoices', '=', True)]}"
                    />
                </group>
                <label for="recurring_invoice_line_ids"
                       attrs="{'invisible': [('recurring_invoices','=',False)]}"
                       />
                <div attrs="{'invisible': [('recurring_invoices','=',False)]}">
                    <field name="recurring_invoice_line_ids">
                        <tree string="Account Analytic Lines" editable="bottom">
                            <field name="sequence" widget="handle" />
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                            <field name="automatic_price"/>
                            <field name="price_unit" attrs="{'readonly': [('automatic_price', '=', True)]}"/>
                            <field name="specific_price" invisible="1"/>
                            <field name="discount" groups="sale.group_discount_per_so_line" />
                            <field name="price_subtotal"/>
                            <field name="analytic_tag_ids" widget="many2many_tags"/>
                        </tree>
                    </field>
                </div>
                                            <notebook>
                        <page string="القراءات المفوترة" id="lines">
                            <div>
                                <field name="recurring_invoice_meterlineinv_ids">
                                    <tree editable="bottom">                            
                                        <field name="name"/>   
                                        <field name="mseterLine_old_reading"/>
                                        <field name="mseterLine_current_reading"/>
                                        <field name="inv_refrid"/>  
                                        <field name="date_readed"/>
                                    </tree>
                                </field>
                                <group class="oe_subtotal_footer oe_right">
                                     <field name="datetime_lastinvreading" class="oe_subtotal_footer_separator"/>
                                     <field name="meter_lastInvo_reading" class="oe_subtotal_footer_separator"/>
                                      <field name="meter_current_reading" class="oe_subtotal_footer_separator"/>
                                    <field name="meter_usedunit" class="oe_subtotal_footer_separator"/>
                                    <field name="meter_canusedunit" class="oe_subtotal_footer_separator"/>
                                    <field name="meter_isinv_ready" class="oe_subtotal_footer_separator"/>
                                </group>
                            </div>
                        </page>
                        <page string="القراءات الجديدة التي لم تفوتر" id="lines">
                            <div>
                                <field name="recurring_invoice_meterline_ids">
                                    <tree editable="bottom">                            
                                        <field name="name"/>   
                                        <field name="mseterLine_old_reading"/>
                                        <field name="mseterLine_current_reading"/>
                                        <field name="date_readed"/>
                                    </tree>
                                </field>
                            </div>
                        </page>
                    </notebook>
                
                <group string="Legend (for the markers inside invoice lines description)"
                       name="group_legend" attrs="{'invisible': [('recurring_invoices','!=',True)]}">
                    <p colspan="2"> <strong>#START#</strong>: Start date of the invoiced period</p>
                    <p colspan="2"> <strong>#END#</strong>: End date of the invoiced period</p>
                </group>
            </group>
        </field>
    </record>

    <!-- Inherited Analytic Account list for contracts -->
    <record id="view_account_analytic_account_journal_tree" model="ir.ui.view">
        <field name="name">Contract list</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_list" />
        <field name="mode">primary</field>
        <field name="priority" eval="9999"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="before">
                 <field name="meter_id"/>
                <field name="journal_id" groups="account.group_account_user"/>
               
            </field>
            <field name="partner_id" position="after">
                <field name="recurring_next_date" invisible="not context.get('is_contract', False)"/>
            </field>
        </field>
    </record>

    <!-- Analytic Account search view for contract -->
    <record id="view_account_analytic_account_contract_search" model="ir.ui.view">
        <field name="name">Contract search</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_search"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="partner_id" position="after">
                    <!-- Use other field because partner_id already used -->
                    <field name="company_id" filter_domain="[('partner_id', 'child_of', self)]"
                           string="Partner and dependents"/>
                </field>
                <field name="meter_id"/>
                <field name="journal_id"/>
                <field name="pricelist_id"/>
                <separator/>
                <filter name="recurring_invoices"
                        string="Recurring Invoices"
                        domain="[('recurring_invoices','=',True)]"
                        />
                <separator/>
                <filter name="not_finished"
                        string="Valid"
                        domain="['|', ('date_end', '=', False), ('date_end', '&gt;=', time.strftime('%Y-%m-%d'))]"
                        />
                <filter name="finished"
                        string="Finished"
                        domain="[('date_end', '&lt;', time.strftime('%Y-%m-%d'))]"
                        />
                <group expand="0" string="Group By...">
                    <filter string="Next Invoice"
                            domain="[]"
                            context="{'group_by':'recurring_next_date'}"
                            />
                    <filter string="Date End"
                            domain="[]"
                            context="{'group_by':'date_end'}"
                            />
                </group>
            </field>
        </field>
    </record>

    <!-- Action Sales/Sales/Contracts -->
    <record id="action_account_analytic_overdue_all" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">account.analytic.account</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'is_contract':1, 'search_default_not_finished':1, 'search_default_recurring_invoices':1, 'default_recurring_invoices': 1}</field>
        <field name="search_view_id" ref="analytic.view_account_analytic_account_search"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new contract.
            </p>
        </field>
    </record>

    <record id="action_account_analytic_overdue_all_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_account_analytic_account_journal_tree"/>
        <field name="act_window_id" ref="action_account_analytic_overdue_all"/>
    </record>

    <record id="action_account_analytic_overdue_all_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="account_analytic_account_recurring_form_form"/>
        <field name="act_window_id" ref="action_account_analytic_overdue_all"/>
    </record>

        
    <record model="ir.ui.view" id="meter_line_view">
            <field name="name">meter.line.tree</field>
            <field name="model">account.analytic.meter.line</field>
            <field name="arch" type="xml">
                <tree string="Meter Line" editable="top" create="true" delete="true">
                    <field name="a_meterline_id" />
                    <field name="mseterLine_current_reading"/>
                    <field name='image' widget="image" class="oe_avatar" resize="320,320" height="80" display="thumbnail"/>
                    <field name="mseterLine_old_reading" readonly="1"/>
                     <field name="name"/>
                    <field name="date_readed"/>
                </tree>
            </field>
        </record>
        
     <record model="ir.ui.view" id="meter_line_inv_view">
            <field name="name">meter.line.invoices.tree</field>
            <field name="model">account.analytic.meter.line.inv</field>
            <field name="arch" type="xml">
                <tree string="Meter Line" editable="top" create="true" delete="true">
                    <field name="a_meterline_id" />
                    <field name="mseterLine_current_reading"/>
                   <!-- <field name='image' widget="image" class="oe_avatar" resize="320,320" height="80" display="thumbnail"/> -->
                    <field name="mseterLine_old_reading" readonly="1"/>
                    <field name="inv_refrid"/>  
                     <field name="name"/>
                    <field name="date_readed"/>
                </tree>
            </field>
        </record>

     <record model="ir.actions.act_window" id="meter_line_action">
            <field name="name">Meter Reading</field>
            <field name="res_model">account.analytic.meter.line</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
           <!-- <field name="domain">[('isinvoced', '=', False)]</field> --> 
            <field name="context">
        {'readonly_by_pass': ['mseterLine_old_reading',]}
    </field>
        </record>
        
        <record model="ir.actions.act_window" id="meter_line_inv_action">
            <field name="name">Meter Invoices Reading</field>
            <field name="res_model">account.analytic.meter.line.inv</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
           <!-- <field name="domain">[('isinvoced', '=', False)]</field> --> 
            <field name="context">
        {'readonly_by_pass': ['mseterLine_old_reading',]}
    </field>
        </record>
        
    <menuitem id="menu_action_account_analytic_overdue_all"
              parent="account.menu_finance_receivables"
              action="action_account_analytic_overdue_all"
              sequence="99"
              />
     <menuitem action="meter_line_action" id="menu_contract_meterline" sequence="100" parent="account.menu_finance_receivables"/>
      <menuitem action="meter_line_inv_action" id="menu_contract_meter_inv_line" sequence="101" parent="account.menu_finance_receivables"/>

</odoo>
